package apps

import "{{ .ModulePath }}/defaults"

"flux-sync": {
	// Namespace + ghcr.io-pull-secret via the shared #Basics (creds in defaults/basics.cue).
	let nsp = defaults.#Basics & {
		#name: "flux-system"

		[...]
	}

	// The webhook Receiver validates GitHub's HMAC signature against this token. Ships as an
	// empty placeholder in committed CUE (like the registry creds); hand-edit before wiring
	// the GitHub webhook.
	let webhookSecretName = "flux-webhook-token"

	let source = {
		apiVersion: "source.toolkit.fluxcd.io/v1"
		kind:       "OCIRepository"
		metadata: {name: "infra", namespace: "flux-system"}
		spec: {
			// Fallback poll — the webhook (below) is the primary, near-instant trigger; this
			// only catches a dropped delivery, so it need not be aggressive.
			interval: "10m"
			url:      "oci://{{ .ImageBase }}"
			ref: tag: "latest"
			secretRef: name: nsp.#out.pull_secret_name
		}
	}

	let kustomize = {
		apiVersion: "kustomize.toolkit.fluxcd.io/v1"
		kind:       "Kustomization"
		metadata: {name: "infra", namespace: "flux-system"}
		spec: {
			interval:  "10m"
			sourceRef: {kind: "OCIRepository", name: "infra"}
			path:      "./"
			prune:     true
			wait:      true
		}
	}

	let webhookToken = {
		apiVersion: "v1"
		kind:       "Secret"
		metadata: {name: webhookSecretName, namespace: "flux-system"}
		type: "Opaque"
		stringData: token: ""
	}

	// Webhook Receiver — the primary, near-instant reconcile trigger. On a GHCR publish
	// GitHub POSTs the registry_package event here; the Receiver validates the signature and
	// pokes the OCIRepository above, whose interval is only the dropped-webhook fallback.
	// Guarded by TestEmbeddedFluxReceiver — do not drop back to poll-only delivery.
	let receiver = {
		apiVersion: "notification.toolkit.fluxcd.io/v1"
		kind:       "Receiver"
		metadata: {name: "infra", namespace: "flux-system"}
		spec: {
			type:   "github"
			events: ["registry_package"]
			secretRef: name: webhookSecretName
			resources: [{
				apiVersion: "source.toolkit.fluxcd.io/v1"
				kind:       "OCIRepository"
				name:       "infra"
				namespace:  "flux-system"
			}]
		}
	}

	// Exposes notification-controller's webhook-receiver service so GitHub can reach it.
	// Attaches to the operator's gateway; the host is per-deployment, hence a render-time var.
	// backendRef is same-namespace (flux-system), so no ReferenceGrant is needed; the gateway's
	// own allowedRoutes must admit this namespace (operator's gateway config).
	_flux_host: string @tag(flux_hostname)
	let webhookRoute = {
		apiVersion: "gateway.networking.k8s.io/v1"
		kind:       "HTTPRoute"
		metadata: {name: "flux-webhook", namespace: "flux-system"}
		spec: {
			parentRefs: [{name: "nginx", namespace: "gateway"}]
			hostnames: [_flux_host]
			rules: [{
				matches: [{path: {type: "PathPrefix", value: "/hook/"}}]
				backendRefs: [{name: "webhook-receiver", port: 80}]
			}]
		}
	}

	"namespace.yaml":   nsp
	"flux-config.yaml": [source, kustomize]
	"webhook.yaml":     [webhookToken, receiver, webhookRoute]
}
