#!/bin/sh
set -e

PLATFORM_MODULE="platform.prodigy9.co"
PLATFORM_VERSION="{{ .PlatformVersion }}"

bindir="$(CDPATH='' cd -- "$(dirname -- "$0")" && pwd)/bin"
# go install names the binary after the module path's last element.
bin="$bindir/$PLATFORM_MODULE"

installed=""
if [ -x "$bin" ]; then
    installed=$(go version -m "$bin" | awk '$1 == "mod" { print $3 }')
fi

if [ "$installed" != "$PLATFORM_VERSION" ]; then
    echo "platform: installing $PLATFORM_VERSION (cold compile may take minutes)..." >&2
    mkdir -p "$bindir"
    printf '*\n' > "$bindir/.gitignore"
    GOBIN="$bindir" go install "$PLATFORM_MODULE@$PLATFORM_VERSION"
fi

exec "$bin" "$@"
