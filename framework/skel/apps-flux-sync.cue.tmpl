package apps

import (
	"{{ .ModulePath }}/defaults"
	"prodigy9.co/defs"
)

"flux-sync": {
	_flux_host: string @tag(flux_hostname)

	let nsp = defaults.#Basics & {
		#name: "flux-system"

		[...]
	}

	// HMAC token GitHub signs the webhook with; plaintext goes in #data before wiring.
	let webhookToken = defs.#Secret & {
		#name: "flux-webhook-token"
		#ns:   nsp.#name
		#data: token: ""
	}

	let source = defs.#FluxOCIRepo & {
		#name:   "infra"
		#ns:     nsp.#name
		#url:    "oci://{{ .ImageBase }}"
		#secret: nsp.#out.pull_secret_name
	}

	let kustomize = defs.#FluxKustomization & {
		#name:        "infra"
		#ns:          nsp.#name
		#source_name: source.#name
	}

	// One org webhook; #target_ns lists every reconciled namespace (owner + tenants), so a
	// GHCR publish pokes each without its own Receiver. Onboarding a tenant appends its ns.
	// TODO(tenant-mode init): scaffold packs.#FluxTenant per tenant — held on its multi-ns fix.
	let receiver = defs.#FluxReceiver & {
		#name:      "infra"
		#ns:        nsp.#name
		#events:    ["registry_package"]
		#secret:    webhookToken.#name
		#target_ns: [nsp.#name]
	}

	let listeners = defaults.#ListenerSet & {
		#name: "flux-listeners"
		#ns:   nsp.#name
		#hosts: [_flux_host]
	}

	let webhookRoute = defs.#HTTPRoute & {
		#name:             "flux-webhook"
		#ns:               nsp.#name
		#listenerset_name: listeners.#name
		#host:             _flux_host
		#rules: [{
			#service_name: "webhook-receiver",
			#service_port: 80,
			#path: "/hook/"
		}]
	}

	// cert-manager's HTTP-01 solver pods run here but carry its labels, so flux's stock netpol
	// blackholes the gateway→solver hop and issuance hangs. Admit :8089 (one-shot challenge).
	// Raw resource: defs.#NetworkPolicy can't select pods labeled by cert-manager, not us.
	let solverIngress = {
		apiVersion: "networking.k8s.io/v1"
		kind:       "NetworkPolicy"
		metadata: {
			name:      "allow-acme-solver"
			namespace: nsp.#name
		}
		spec: {
			podSelector: matchLabels: "acme.cert-manager.io/http01-solver": "true"
			policyTypes: ["Ingress"]
			ingress: [{
				ports: [{port: 8089}]
			}]
		}
	}

	"namespace.yaml":   nsp
	"flux-config.yaml": [source, kustomize]
	"webhook.yaml":     [webhookToken, receiver, listeners, webhookRoute, solverIngress]
}
